# ===========================================================
# Mission Control — variables d'environnement (exemple)
# Copie ce fichier vers .env et ajuste les valeurs.
# .env est gitignored.
# ===========================================================

# --- Backend FastAPI ---
APP_NAME=mission-control
APP_ENV=dev                            # dev | prod
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

# --- Base de données ---
# SQLite locale par défaut. Chemin relatif au backend/ (ex: ../data/mission-control.db)
DATABASE_URL=sqlite:///../data/mission-control.db

# --- Localisation ---
TIMEZONE=America/Montreal
LOCALE=fr-CA

# --- CORS ---
# Origines autorisées séparées par des virgules.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend Next.js (lu côté client) ---
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# --- Agent IA (CONV 12, pas utilisé en CONV 1) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Finance (CONV 4) ---
# Cache yfinance par exemple
# YFINANCE_CACHE_DIR=../data/yfinance_cache
