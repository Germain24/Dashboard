# ===========================================================
# Mission Control — variables d'environnement (exemple)
# Copie ce fichier vers .env et ajuste les valeurs.
# .env est gitignored.
# ===========================================================

# --- Backend FastAPI ---
APP_NAME=mission-control
APP_ENV=dev                            # dev | prod
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

# --- Base de données ---
# SQLite locale par défaut. Chemin relatif au backend/ (ex: ../data/mission-control.db)
DATABASE_URL=sqlite:///../data/mission-control.db

# --- Localisation ---
TIMEZONE=America/Montreal
LOCALE=fr-CA

# --- CORS ---
# Origines autorisées séparées par des virgules.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend Next.js (lu côté client) ---
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# --- Agent IA (CONV 12, pas utilisé en CONV 1) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Finance (CONV 4) ---
# Cache yfinance par exemple
# YFINANCE_CACHE_DIR=../data/yfinance_cache

# --- Google Calendar (Agenda #83, OAuth) ---
# Intégration lecture/écriture autonome. Laisse vide pour la désactiver.
# Obtention : créer un client OAuth « Desktop app » dans Google Cloud + activer
# Google Calendar API, puis lancer :
#   python backend/scripts/google_oauth_setup.py --client-id XXX --client-secret YYY
# (le script affiche le refresh_token à coller ici).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# --- Garde-robe (CONV 2) ---
# Clé OpenWeather (https://openweathermap.org/api). Tier "Free" suffit.
# Si vide, fallback automatique sur Open-Meteo (gratuit, sans clé).
OPENWEATHER_API_KEY=
# Coordonnées par défaut (Montréal)
GARDEROBE_LAT=45.5017
GARDEROBE_LON=-73.5673
# Fenêtre horaire considérée pour la cible thermique (heures locales)
GARDEROBE_HOUR_START=7
GARDEROBE_HOUR_END=23
# TTL du cache météo (secondes)
GARDEROBE_WEATHER_CACHE_TTL=1800

# ─────────────────────────────────────────────────────────────────────
# Réglages métier ajustables (toutes ces variables ont une valeur par
# défaut dans le code ; les renseigner ici ne fait que la surcharger).
# ─────────────────────────────────────────────────────────────────────

# --- Finance : score Buffett & valorisation ---
BUFFETT_SCORE_THRESHOLD=80.0        # score d'achat minimal
BUFFETT_PER_MAX=40.0                # PER maximal toléré
BUFFETT_PEG_MAX=1.0                 # PEG maximal toléré
BUFFETT_TAUX_DEFAUT=0.04            # taux obligataire par défaut
# --- Finance : optimiseur d'allocation ---
BUFFETT_SHARPE_TARGET_PERCENT=0.90
BUFFETT_MIN_ALLOCATION_THRESHOLD=0.01
BUFFETT_N_MULTISTART=5
BUFFETT_DEDUP_FUZZY_THRESHOLD=0.80
# --- Finance : alertes ---
FINANCE_REBALANCE_ALERT_PCT=5.0     # écart de poids (pts) déclenchant une alerte
FINANCE_SNAPSHOT_DROP_ALERT_PCT=5.0 # chute quotidienne (%) alertée

# --- Santé : optimisation nutritionnelle ---
SANTE_MAINTENANCE_KCAL_PER_KG=32.0  # maintenance = poids × ce facteur
SANTE_SURPLUS_KCAL_SPORT=500.0      # surplus calorique un jour de sport
SANTE_REST_FACTOR=1.1               # multiplicateur jours de repos

# --- Entraînement : volume (séries/sem par muscle) + mésocycle ---
ENTRAINEMENT_SETS_MEV=10            # Minimum Effective Volume
ENTRAINEMENT_SETS_MRV=20            # Maximum Recoverable Volume
ENTRAINEMENT_MESOCYCLE_ACCUMULATION_WEEKS=4

# --- Budget : seuils d'alerte d'enveloppe (% du budget consommé) ---
BUDGET_ENVELOPE_WARNING_PCT=80.0
BUDGET_ENVELOPE_OVER_PCT=100.0

# Restreindre l'analyse aux titres achetables (ToutBroker.xlsx) : ~38x plus rapide.
# false = analyser tout tickers.csv (~65k, plusieurs jours).
BUFFETT_LIMIT_TO_BROKER_UNIVERSE=true
