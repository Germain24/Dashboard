# ===========================================================
# Mission Control — variables d'environnement (exemple)
# Copie ce fichier vers .env et ajuste les valeurs.
# .env est gitignored — ne commite JAMAIS de secret réel. Au démarrage, le
# backend journalise quelles intégrations sont configurées, sans révéler les
# valeurs (secrets masqués, cf. app/core/secrets.py).
# ===========================================================

# --- Backend FastAPI ---
APP_NAME=mission-control
APP_ENV=dev                            # dev | prod
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

# --- Base de données ---
# SQLite locale par défaut. Chemin relatif au backend/ (ex: ../data/mission-control.db)
DATABASE_URL=sqlite:///../data/mission-control.db

# --- Localisation ---
TIMEZONE=America/Montreal
LOCALE=fr-CA

# --- CORS ---
# Origines, méthodes et en-têtes autorisés (listes séparées par des virgules,
# pas de wildcard "*"). Laisser les valeurs par défaut convient en local.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# --- Frontend Next.js (lu côté client) ---
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# --- Finance (CONV 4) ---
# Cache yfinance par exemple
# YFINANCE_CACHE_DIR=../data/yfinance_cache

# --- Google Calendar (Agenda #83, OAuth) ---
# Intégration lecture/écriture autonome. Laisse vide pour la désactiver.
# Obtention : créer un client OAuth « Desktop app » dans Google Cloud + activer
# Google Calendar API, puis lancer :
#   python backend/scripts/google_oauth_setup.py --client-id XXX --client-secret YYY
# (le script affiche le refresh_token à coller ici).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# --- Calendriers iCal externes (Agenda) ---
# URLs .ics re-synchronisées automatiquement toutes les 6h (ex. Agendrix).
# Plusieurs URLs séparées par des virgules. Vide = synchro auto désactivée.
ICAL_SYNC_URLS=

# --- Garde-robe (CONV 2) ---
# Clé OpenWeather (https://openweathermap.org/api). Tier "Free" suffit.
# Si vide, fallback automatique sur Open-Meteo (gratuit, sans clé).
OPENWEATHER_API_KEY=
# Coordonnées par défaut (Montréal)
GARDEROBE_LAT=45.5017
GARDEROBE_LON=-73.5673
# Fenêtre horaire considérée pour la cible thermique (heures locales)
GARDEROBE_HOUR_START=7
GARDEROBE_HOUR_END=23
# TTL du cache météo (secondes)
GARDEROBE_WEATHER_CACHE_TTL=1800

# ─────────────────────────────────────────────────────────────────────
# Réglages métier ajustables (toutes ces variables ont une valeur par
# défaut dans le code ; les renseigner ici ne fait que la surcharger).
# ─────────────────────────────────────────────────────────────────────

# --- Finance : score Buffett & valorisation ---
BUFFETT_SCORE_THRESHOLD=80.0        # score d'achat minimal
BUFFETT_PER_MAX=40.0                # PER maximal toléré
BUFFETT_PEG_MAX=1.0                 # PEG maximal toléré
BUFFETT_TAUX_DEFAUT=0.04            # taux obligataire par défaut
# Débit yfinance : plafond horaire glissant (au-delà, l'analyse se met en pause
# automatiquement — voir la barre « En pause »). Monter réduit les pauses mais
# augmente le risque de 429 côté Yahoo. 2000/h ÷ 4 req/titre = 500 titres/h.
BUFFETT_MAX_REQUESTS_PER_HOUR=2000
BUFFETT_REQUESTS_PER_TICKER=4
# --- Finance : optimiseur d'allocation ---
BUFFETT_SHARPE_TARGET_PERCENT=0.90
BUFFETT_MIN_ALLOCATION_THRESHOLD=0.01
BUFFETT_N_MULTISTART=5
BUFFETT_DEDUP_FUZZY_THRESHOLD=0.80
# --- Finance : alertes ---
FINANCE_REBALANCE_ALERT_PCT=5.0     # écart de poids (pts) déclenchant une alerte
FINANCE_SNAPSHOT_DROP_ALERT_PCT=5.0 # chute quotidienne (%) alertée

# --- Santé : optimisation nutritionnelle ---
SANTE_MAINTENANCE_KCAL_PER_KG=32.0  # maintenance = poids × ce facteur
SANTE_SURPLUS_KCAL_SPORT=500.0      # surplus calorique un jour de sport
SANTE_REST_FACTOR=1.1               # multiplicateur jours de repos

# --- Entraînement : volume (séries/sem par muscle) + mésocycle ---
ENTRAINEMENT_SETS_MEV=10            # Minimum Effective Volume
ENTRAINEMENT_SETS_MRV=20            # Maximum Recoverable Volume
ENTRAINEMENT_MESOCYCLE_ACCUMULATION_WEEKS=4

# --- Budget : seuils d'alerte d'enveloppe (% du budget consommé) ---
BUDGET_ENVELOPE_WARNING_PCT=80.0
BUDGET_ENVELOPE_OVER_PCT=100.0

# Exclure les titres presents dans ToutBroker.xlsx dont TOUS les brokers sont
# explicitement Faux (cellule vide != Faux). Tout le reste est analyse.
BUFFETT_EXCLUDE_UNAVAILABLE=true
# Plafond yfinance/heure (anti-ban) + requetes par ticker. Monter accelere
# l'analyse mais augmente le risque de ban Yahoo.
BUFFETT_MAX_REQUESTS_PER_HOUR=2000
BUFFETT_REQUESTS_PER_TICKER=4
# Pause max (secondes) quand le quota horaire est atteint. Bornee pour re-tenter
# vite plutot que d'attendre la fenetre theorique (~1 h). Defaut : 120 (2 min).
BUFFETT_RATE_LIMIT_MAX_PAUSE_SEC=120
# Rotation d'IP : proxys separes par des virgules. La session yfinance en choisit
# un au hasard, et en change a chaque pause de quota. Vide = connexion directe.
# Ex : YF_PROXIES=http://user:pass@host1:port,http://host2:port
YF_PROXIES=

# --- API Claude (Anthropic) ---
# Classement musical des NOUVEAUX morceaux par lots (fiable). Vide = fallback
# sur Ollama local (unitaire, lent). Clé : https://platform.claude.com
ANTHROPIC_API_KEY=
# Modèle utilisé pour le classement (claude-haiku-4-5 = option plus économique).
MUSIQUE_CLAUDE_MODEL=claude-opus-4-8

# --- API DeepSeek (classement musical alternatif, compatible OpenAI) ---
# Si renseignée, DeepSeek est utilisé en PRIORITÉ pour le classement par lots
# (avant Claude, avant Ollama). Clé : https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
MUSIQUE_DEEPSEEK_MODEL=deepseek-chat

# --- Musique (playlists par ambiance, Ollama local) ---
MUSIC_DIR=C:/Users/germa/Music
MUSIQUE_OLLAMA_HOST=http://localhost:11434
MUSIQUE_OLLAMA_MODEL=qwen2.5:3b
# Démarrer automatiquement `ollama serve` au lancement du backend s'il n'est pas actif.
MUSIQUE_OLLAMA_AUTOSTART=true
# Forcer Ollama en CPU (le backend GPU/Vulkan plante sur certains iGPU Intel).
MUSIQUE_OLLAMA_FORCE_CPU=true
