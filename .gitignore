# --- Données / DB ---
# Bases SQLite (et sidecars WAL/SHM/journal) où qu'elles soient : elles
# contiennent les données personnelles saisies dans l'app (finance, fiscalité,
# santé…). Le dépôt est public — ne JAMAIS les versionner.
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
# imports/ tracked via .gitkeep, contents ignored
data/imports/*
!data/imports/.gitkeep
# Données financières téléchargées (xlsx par société) + sauvegardes + cache : générées, jamais versionnées.
backend/data/financials_by_company/
data/backups/
backend/data/cache_status.json
# Soldes de comptes mémorisés à l'import (relevés) — données bancaires, jamais versionnées.
data/account_balances.json
backend/data/account_balances.json

