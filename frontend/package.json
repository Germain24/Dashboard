    "@tanstack/react-query-persist-client": "^5.100.14",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.5.4",
